# M3U Editör Pro - Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# Uygulama Ayarları
APP_ENV=production
DEBUG_MODE=false

# Sunucu Ayarları
SERVER_PORT=8501
SERVER_HOST=localhost

# Güvenlik
ENABLE_SSL_VERIFY=false
MAX_FILE_SIZE_MB=50

# Özellikler
ENABLE_VISITOR_COUNTER=true
ENABLE_LIVE_PLAYER=true
ENABLE_URL_HEALTH_CHECK=true

# Varsayılan Ayarlar
DEFAULT_TR_FILTER=true
DEFAULT_THEME=dark
