# M3U Editör Pro - Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# === Uygulama Ayarları ===
APP_NAME="M3U Editör Pro"
APP_VERSION="1.0.0"
APP_ENV="development"  # development, staging, production
APP_DEBUG="true"

# === Streamlit Ayarları ===
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=false
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# === Database Ayarları (opsiyonel) ===
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=m3u_editor
# DB_USER=postgres
# DB_PASSWORD=your_password

# === Redis Ayarları (opsiyonel) ===
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# === Cache Ayarları ===
CACHE_TTL=300  # saniye
CACHE_ENABLED=true

# === Logging Ayarları ===
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# === Güvenlik Ayarları ===
SECRET_KEY=your_secret_key_here_change_this_in_production
ALLOWED_HOSTS=localhost,127.0.0.1

# === Performans Ayarları ===
MAX_FILE_SIZE_MB=50
MAX_CHANNELS_PER_REQUEST=10000
REQUEST_TIMEOUT=30

# === TR Filtre Ayarları ===
TR_FILTER_ENABLED=true
TR_KEYWORDS=TR,TURK,TÜRK,TURKIYE,TÜRKİYE,YERLI,ULUSAL,ISTANBUL

# === Export Ayarları ===
DEFAULT_EXPORT_FORMAT=m3u  # m3u, json, csv
EXPORT_FILENAME_PREFIX="iptv_listesi"
EXPORT_INCLUDE_TIMESTAMP=true